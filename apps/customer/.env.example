# SplashSphere Connect (customer app)
# Copy to .env.local and adjust as needed.

# Backend API base URL (Connect endpoints live under /api/v1/connect/*)
NEXT_PUBLIC_API_URL=http://localhost:5221

# Optional — pre-fills the OTP code input in development. Only set this when
# the backend has `Otp:FixedCode` configured to the same value. Never set in
# production. See Key Business Rule #25 in CLAUDE.md.
# NEXT_PUBLIC_DEV_OTP_CODE=123456
