# SplashSphere Connect (customer app)
# Copy to .env.local and adjust as needed.

# Backend API base URL (Connect endpoints live under /api/v1/connect/*)
NEXT_PUBLIC_API_URL=http://localhost:5221

# Optional — pre-fills the OTP code input in development. Only set this when
# the backend has `Otp:FixedCode` configured to the same value. Never set in
# production. See Key Business Rule #25 in CLAUDE.md.
# NEXT_PUBLIC_DEV_OTP_CODE=123456

# Optional — override the default OpenStreetMap tile URL used by the Discover
# map view. Useful in production where OSM's tile servers throttle high-volume
# anonymous traffic. Free alternatives:
#   - MapTiler: https://cloud.maptiler.com (100k loads/mo free, requires key)
#   - Stadia:   https://docs.stadiamaps.com (free for low-volume use)
# Use the standard `{z}/{x}/{y}.png` placeholder; we substitute them at runtime.
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors
