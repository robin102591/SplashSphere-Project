# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=splashsphere_dev;Username=postgres;Password=postgres

# Clerk
Clerk__Authority=https://YOUR_INSTANCE.clerk.accounts.dev
Clerk__SecretKey=sk_test_xxxxx

# PayMongo (optional — omit to use mock gateway in dev)
PayMongo__SecretKey=sk_test_xxxxx
PayMongo__PublicKey=pk_test_xxxxx
PayMongo__WebhookSecret=whsec_xxxxx

# Resend (optional — omit to use mock email service in dev)
Resend__ApiKey=re_xxxxx
Resend__FromEmail=SplashSphere <noreply@splashsphere.ph>

# Semaphore SMS (optional — omit to use mock SMS service in dev)
Semaphore__ApiKey=xxxxx
Semaphore__SenderName=SplashSphere

# Next.js Admin App
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Next.js POS App
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
