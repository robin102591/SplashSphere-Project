# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=splashsphere_dev;Username=postgres;Password=postgres

# Clerk
Clerk__Authority=https://YOUR_INSTANCE.clerk.accounts.dev
Clerk__SecretKey=sk_test_xxxxx

# PayMongo (optional — omit to use mock gateway in dev)
PayMongo__SecretKey=sk_test_xxxxx
PayMongo__PublicKey=pk_test_xxxxx
PayMongo__WebhookSecret=whsec_xxxxx

# Resend (optional — omit to use mock email service in dev)
Resend__ApiKey=re_xxxxx
Resend__FromEmail=SplashSphere <noreply@splashsphere.ph>

# Semaphore SMS (optional — omit to use mock SMS service in dev)
Semaphore__ApiKey=xxxxx
Semaphore__SenderName=SplashSphere

# SplashSphere Connect — Customer app JWT (separate from Clerk)
# SigningKey MUST be ≥ 32 bytes in production. Generate with: openssl rand -base64 48
Jwt__Connect__SigningKey=CHANGE_ME_DEV_KEY_32_BYTES_MIN_FOR_HS256_SIGNING
Jwt__Connect__Issuer=splashsphere-api
Jwt__Connect__Audience=splashsphere.connect
Jwt__Connect__AccessTokenMinutes=30
Jwt__Connect__RefreshTokenDays=30

# SplashSphere Connect — OTP (phone auth)
# Set Otp__FixedCode in dev to bypass real SMS (any phone accepts this code).
# Leave blank or unset in production for cryptographically random codes.
Otp__FixedCode=123456
Otp__CodeLength=6
Otp__TtlMinutes=5

# Next.js Admin App
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Next.js POS App
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
